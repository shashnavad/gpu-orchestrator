FROM rust:1.86-slim-bookworm AS builder
WORKDIR /app
COPY Cargo.toml .
# Pre-fetch dependencies before copying source (layer cache).
RUN mkdir src && echo 'fn main(){}' > src/main.rs && \
    cargo build --features mock --release && \
    rm src/main.rs
COPY src ./src
# Touch main.rs so cargo rebuilds it rather than using the dummy above.
RUN touch src/main.rs && cargo build --features mock --release

FROM debian:bookworm-slim
WORKDIR /app
# FIX: Install CA certificates so reqwest can initialize its network client
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/gpu-agent .
EXPOSE 9090
CMD ["./gpu-agent"]
